# ====== x402-signature-service Konfiguration ======
# Kopieren nach .env und Werte eintragen.

# development | production  (production verweigert Start mit Fake/Bypass-Flags)
APP_ENV=development

# --- Zahlung / x402 ---
# Base-Wallet-Adresse, auf der USDC-Zahlungen ankommen (PFLICHT fuer Produktion)
PAY_TO_ADDRESS=0xE72b85A97A6e19413D8b80633787Eda6d6237A77
# Netzwerk: Base Mainnet = eip155:8453 | Base Sepolia (Test) = eip155:84532
X402_NETWORK=eip155:8453
# Preis pro Signaturanfrage (USDC)
SIGNATURE_REQUEST_PRICE_USD=$0.50
# Facilitator:
#  - Base Mainnet, ohne API-Keys:  https://facilitator.payai.network
#  - Base Sepolia (Test):          https://x402.org/facilitator
#  - Coinbase CDP (fuer automatisches Bazaar-Listing, API-Keys noetig):
#      FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
#      CDP_API_KEY_ID=...
#      CDP_API_KEY_SECRET=...
FACILITATOR_URL=https://facilitator.payai.network
#CDP_API_KEY_ID=
#CDP_API_KEY_SECRET=

# Lokale Entwicklung: Bezahlschranke komplett deaktivieren (NIE in Produktion!)
X402_BYPASS_FOR_LOCAL_DEVELOPMENT=false

# --- Service ---
BASE_URL=http://localhost:8000
SERVICE_NAME=x402-signature-service
DATABASE_PATH=./data/signature-service.db

# --- Signatur-Provider ---
# documenso (Produktion) | fake (lokale Entwicklung, simuliert Unterschriften)
SIGNATURE_PROVIDER=documenso
DOCUMENSO_BASE_URL=https://app.documenso.com
DOCUMENSO_API_TOKEN=api_xxxxxxxxxxxxxxxx
# Webhook in Documenso anlegen: URL = <BASE_URL>/webhooks/documenso, Secret hier eintragen
DOCUMENSO_WEBHOOK_SECRET=change-me

# --- Limits & Retention ---
MAX_PDF_BYTES=5242880
STATUS_CACHE_SECONDS=15
PURGE_AFTER_DAYS=30
FAKE_AUTOSIGN_SECONDS=5
